---
import Base from '../layouts/Base.astro';
import business from '../data/business.json';
---

<Base
  title="Contact"
  description="Contact the North American Upholstery Guild. Reach us by phone, email, or mail for membership inquiries and general questions."
>
  <section class="page-header noise-grain">
    <div class="container">
      <h1>Contact Us</h1>
      <hr class="divider divider-center page-divider" />
      <p class="page-subtitle">
        We're here to answer your questions about the Guild and membership.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-info">
        <h2>Get in Touch</h2>
        <hr class="divider" />
        <p class="contact-intro">
          Whether you're interested in membership, have questions about our
          programs, or want to learn more about the Guild, we welcome your inquiry.
        </p>

        <div class="contact-methods">
          <div class="contact-method">
            <h3>Phone</h3>
            <a href={`tel:${business.telephone}`}>{business.telephoneDisplay}</a>
          </div>

          <div class="contact-method">
            <h3>Email</h3>
            <a href={`mailto:${business.email}`}>{business.email}</a>
          </div>

          <div class="contact-method">
            <h3>Mailing Address</h3>
            <address>
              <p>{business.name}</p>
              <p>{business.address.streetAddress}</p>
              <p>{business.address.addressLocality}, {business.address.addressRegion} {business.address.postalCode}</p>
              <p>{business.address.addressCountry === 'CA' ? 'Canada' : business.address.addressCountry}</p>
            </address>
          </div>
        </div>
      </div>

      <div class="contact-aside">
        <div class="aside-card">
          <h3>Membership Inquiries</h3>
          <p>
            Interested in joining the Guild? Email us with a brief description
            of your business and location, and a member of our team will be
            in touch to discuss how the Guild can support your goals.
          </p>
          <a href={`mailto:${business.email}?subject=Membership%20Inquiry`} class="btn btn-primary">
            Email About Membership
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-header {
    background: var(--color-primary);
    color: #fff;
    padding: 3.5rem 0;
    text-align: center;
  }

  .page-header h1 { color: #fff; margin-bottom: 0.75rem; }
  .page-divider { background: var(--color-accent); margin-bottom: 1rem; }
  .page-subtitle { font-size: 1.1rem; opacity: 0.9; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    align-items: flex-start;
  }

  .contact-intro {
    color: var(--color-text-muted);
    font-size: 1.02rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .contact-method h3 {
    font-size: 0.85rem;
    font-family: var(--font-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary);
    margin-bottom: 0.3rem;
  }

  .contact-method a {
    color: var(--color-text);
    font-size: 1.05rem;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-border);
  }

  .contact-method a:hover {
    color: var(--color-primary);
    text-decoration-color: var(--color-primary);
  }

  .contact-method address {
    font-style: normal;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .aside-card {
    padding: 2rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }

  .aside-card h3 {
    margin-bottom: 0.75rem;
    color: var(--color-primary-dark);
  }

  .aside-card p {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
