---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
}

const hasSelfHostedVideo = post.data.type === 'video' && !!post.data.videoUrl;
const hasYouTubeVideo = post.data.type === 'video' && !!post.data.youtubeId && !post.data.videoUrl;
const videoPlanned = post.data.type === 'video' && !post.data.videoUrl && !post.data.youtubeId;
---

<Base title={post.data.title} description={post.data.description}>
  <article>
    <header class="post-header noise-grain">
      <div class="container">
        <div class="post-header-meta">
          <a href="/blog" class="back-link">&larr; Blog</a>
          {post.data.type === 'video' && (
            <span class="badge-video">Video</span>
          )}
        </div>
        <h1>{post.data.title}</h1>
        <hr class="divider divider-center page-divider" />
        <p class="post-lead">{post.data.description}</p>
        <time datetime={post.data.pubDate.toISOString()} class="post-date">
          {formatDate(post.data.pubDate)}
        </time>
        {post.data.tags && (
          <ul class="tag-list">
            {post.data.tags.map(tag => (
              <li class="tag">{tag}</li>
            ))}
          </ul>
        )}
      </div>
    </header>

    {hasSelfHostedVideo && (
      <div class="video-wrapper">
        <div class="container">
          <div class="video-embed">
            <video
              controls
              preload="metadata"
              src={post.data.videoUrl}
            >
              Your browser does not support the video element.
            </video>
          </div>
        </div>
      </div>
    )}

    {hasYouTubeVideo && (
      <div class="video-wrapper">
        <div class="container">
          <div class="video-embed">
            <iframe
              src={`https://www.youtube.com/embed/${post.data.youtubeId}`}
              title={post.data.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </div>
    )}

    {videoPlanned && (
      <div class="video-placeholder-wrapper">
        <div class="container">
          <div class="video-placeholder">
            <p>Video coming soon.</p>
          </div>
        </div>
      </div>
    )}

    <div class="post-body section">
      <div class="container">
        <div class="prose">
          <Content />
        </div>
      </div>
    </div>
  </article>

  <div class="post-footer section section-alt">
    <div class="container post-footer-inner">
      <div>
        <p class="post-footer-label">North American Upholstery Guild</p>
        <p class="post-footer-sub">Industry guidance for upholstery business owners.</p>
      </div>
      <a href="/blog" class="btn btn-outline">Back to Blog</a>
    </div>
  </div>
</Base>

<style>
  .post-header {
    background: var(--color-primary);
    color: #fff;
    padding: 3.5rem 0 2.5rem;
    text-align: center;
  }

  .post-header h1 {
    color: #fff;
    margin-bottom: 0.75rem;
    max-width: 780px;
    margin-inline: auto;
  }

  .post-header-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .back-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    transition: color 0.15s;
  }

  .back-link:hover {
    color: #fff;
  }

  .badge-video {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    background: var(--color-accent);
    color: #fff;
    padding: 0.2rem 0.55rem;
    border-radius: 3px;
  }

  .page-divider { background: var(--color-accent); margin-bottom: 1rem; }

  .post-lead {
    font-size: 1.05rem;
    opacity: 0.9;
    max-width: 680px;
    margin-inline: auto;
    margin-bottom: 1.25rem;
    line-height: 1.7;
  }

  .post-date {
    display: block;
    font-size: 0.85rem;
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
  }

  .tag {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.15);
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    font-weight: 500;
  }

  /* Video embed */
  .video-wrapper {
    background: #111;
    padding: 2.5rem 0;
  }

  .video-embed {
    position: relative;
    width: 100%;
    max-width: 860px;
    margin-inline: auto;
    aspect-ratio: 16 / 9;
  }

  .video-embed iframe,
  .video-embed video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    border-radius: 4px;
  }

  /* Video planned placeholder */
  .video-placeholder-wrapper {
    background: var(--color-bg-alt);
    padding: 2rem 0;
  }

  .video-placeholder {
    max-width: 860px;
    margin-inline: auto;
    border: 2px dashed var(--color-border);
    border-radius: 4px;
    padding: 2.5rem;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-style: italic;
  }

  /* Prose styles for markdown body */
  .prose {
    max-width: 720px;
    font-size: 1.02rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .prose :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    color: var(--color-primary-dark);
  }

  .prose :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .prose :global(h4) {
    margin-top: 1.5rem;
    margin-bottom: 0.4rem;
    font-size: 1rem;
    font-family: var(--font-body);
    font-weight: 700;
    color: var(--color-text);
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    list-style: disc;
  }

  .prose :global(ol) {
    list-style: decimal;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 0.5rem 0 0.5rem 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .prose :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
    margin: 2rem 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.92rem;
  }

  .prose :global(th),
  .prose :global(td) {
    text-align: left;
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(th) {
    font-weight: 700;
    color: var(--color-text);
    border-bottom: 2px solid var(--color-border);
  }

  .prose :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) {
    color: var(--color-primary-dark);
  }

  /* Post footer */
  .post-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .post-footer-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.2rem;
  }

  .post-footer-sub {
    font-size: 0.88rem;
    color: var(--color-text-muted);
  }
</style>
